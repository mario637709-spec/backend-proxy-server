# Server Configuration
PORT=3000
NODE_ENV=production

# CORS (comma-separated frontend URLs)
ALLOWED_ORIGINS=https://your-frontend.onrender.com,https://localhost:5173

# Redis Configuration (Use Redis Cloud free tier)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional: For Redis Cloud
# REDIS_HOST=redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com
# REDIS_PORT=12345
# REDIS_PASSWORD=your-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Download Proxy Settings
MAX_PROXY_FILE_SIZE_MB=100

# Logging
LOG_LEVEL=info
